    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.18",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jose": "^5.9.6",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.454.0",
    "mammoth": "^1.12.0",
    "next": "14.2.18",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
