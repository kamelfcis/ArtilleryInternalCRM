{
  "name": "artillery-crm",
  "version": "0.1.0",
  "private": true,
  "description": "نظام إدارة الوثائق وعلاقات الجهات لقسم الاحتياجات - إدارة المدفعية",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node scripts/prebuild-clear-logs.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "import:documents": "tsx scripts/import-documents.ts",
    "ocr:documents": "tsx scripts/ocr-documents.ts",
    "extract:documents": "tsx scripts/extract-documents.ts",
    "link:documents": "tsx scripts/link-documents.ts",
    "bootstrap:crm": "tsx scripts/bootstrap-crm.ts",
    "validate:hybrid": "tsx scripts/validate-hybrid-extraction.ts",
    "seed:crm": "tsx scripts/seed-crm.ts",
    "postinstall": "prisma generate",
    "migrate:turso": "tsx scripts/migrate-to-turso.ts",
    "migrate:blob": "tsx scripts/migrate-storage-to-blob.ts",
    "db:clear-logs": "tsx scripts/clear-logs.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@libsql/client": "^0.8.1",
    "@napi-rs/canvas": "^1.0.2",
