# ==========================================================================
# Environment template — copy to `.env` and adjust (never commit `.env`).
# ==========================================================================

# --- Database (local dev) -------------------------------------------------
DATABASE_URL="file:./dev.db"

# --- Turso (production on Vercel) -----------------------------------------
# TURSO_DATABASE_URL="libsql://your-db-name-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-database-token"

# --- Authentication -------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="change-me-to-a-long-random-secret-value-please"
SESSION_MAX_AGE="28800"

# --- Document storage -----------------------------------------------------
STORAGE_ROOT="./storage"
MAX_UPLOAD_MB="50"

# Vercel Blob (production). Omit locally to use STORAGE_ROOT on disk.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- AI extraction (optional) -------------------------------------------
# ANTHROPIC_API_KEY=""
# GEMINI_API_KEY=""

# --- Bootstrap admin (`npm run db:seed` only) -----------------------------
SEED_ADMIN_NAME="مدير النظام"
SEED_ADMIN_EMAIL="admin@artillery.local"
SEED_ADMIN_PASSWORD="Admin@12345"
